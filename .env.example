# =====================================================
# Accounts.Life — Environment Variables
# =====================================================
# Copy this file to .env and fill in your values.
# On Vercel, add each variable via the Dashboard.

# PostgreSQL / Neon DB connection string
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require"

# Public site URL (no trailing slash)
# Set to your Vercel deployment URL or custom domain
NEXT_PUBLIC_SITE_URL="https://accounts.life"

# Admin portal PIN (used for /admin/login)
ADMIN_PASSWORD="your-secure-password-here"
