# =====================================================
# Accounts.One — Environment Variables
# =====================================================
# Copy this file to .env and fill in your values.
# IMPORTANT: ALL variables must be set in Vercel Dashboard > Settings > Environment Variables.

# PostgreSQL / Neon DB connection string
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require"

# Public site URL (no trailing slash)
# Set to your Vercel deployment URL or custom domain
NEXT_PUBLIC_SITE_URL="https://accounts.one"

# Admin portal password (used for /admin/login)
# REQUIRED — if not set, admin login will be disabled entirely.
ADMIN_PASSWORD="your-secure-password-here"

# Admin HMAC secret for session token signing
# REQUIRED — use a random 32+ character string. Generate with: openssl rand -hex 32
ADMIN_SECRET="your-random-32-char-secret-here"
